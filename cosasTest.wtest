import cosas.*

describe "test paquete, bateria, contenedor y embalaje" {

  test "el contenedor pesa 960 si le metemos embalaje,residuos y bumblebee" {
  residuos.peso(30)
  embalaje.cambiarCosaQueEnvuelve(residuos)
  contenedor.meterElementos([embalaje, residuos, bumblebee])
  assert.equals(30 + 30 + 800 + 100, contenedor.peso())
  }

}